# ── n8n MCP Backup Stack – Environment Variables ─────────────────────────────
# Copy to .env and fill in all REQUIRED values before running docker compose up.
# Never commit .env to git.

# ── n8n ───────────────────────────────────────────────────────────────────────
# REQUIRED: stable 32-byte hex key for n8n credential encryption.
# Generate with: openssl rand -hex 32
# WARNING: If this changes, all stored n8n credentials become unreadable.
N8N_ENCRYPTION_KEY=your_random_32_byte_hex_here

# REQUIRED: n8n API key (created in the UI after first boot).
# Steps: Settings → n8n API → Create API Key
# Then restart the MCP server: docker compose restart mcp-server
N8N_API_KEY=your_n8n_api_key_here

# Optional – only needed if n8n is not on the default Docker network alias
# N8N_URL=http://n8n:5678

# ── Garage S3 Object Storage ──────────────────────────────────────────────────
# REQUIRED: shared RPC secret for Garage cluster authentication.
# Generate with: openssl rand -hex 32
GARAGE_RPC_SECRET=your_garage_rpc_secret_here

# REQUIRED: admin API token for Garage (used by garage-webui).
# Generate with: openssl rand -base64 32
GARAGE_ADMIN_TOKEN=your_garage_admin_token_here

# REQUIRED: S3 access key ID created in Garage after first boot.
S3_ACCESS_KEY_ID=your_s3_access_key_id_here

# REQUIRED: S3 secret access key created in Garage after first boot.
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key_here

# Bucket name for n8n backups (default shown).
S3_BUCKET=n8n-backup

# Bucket name for Postgres backups (default shown).
S3_BUCKET_POSTGRES=postgres-backup

# S3 endpoint (default points to garage service on the Docker network).
S3_ENDPOINT=http://garage:3900

# S3 region string (match whatever your Garage config uses).
S3_REGION=us-east-1

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# REQUIRED: database name to create on first boot.
POSTGRES_DB=your_postgres_db_here

# REQUIRED: superuser name for the database.
POSTGRES_USER=your_postgres_user_here

# REQUIRED: superuser password. Use a strong random value in production.
POSTGRES_PASSWORD=your_postgres_password_here

# PostgreSQL connection details for the MCP server (pg_dump / pg_restore).
PG_HOST=postgres
PG_PORT=5432
PG_DB=your_postgres_db_here
PG_USER=your_postgres_user_here
PG_PASSWORD=your_postgres_password_here
